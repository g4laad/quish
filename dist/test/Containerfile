# Rootful test image for the privsep e2e harness. Build from the workspace root:
#   podman build -t quish-privsep-e2e -f dist/test/Containerfile .
FROM docker.io/library/rust:1-bookworm

# PAM: build deps (bindgen needs libclang + libpam headers) and the runtime lib.
RUN apt-get update && apt-get install -y --no-install-recommends \
        clang libclang-dev libpam0g-dev libpam0g procps && \
    rm -rf /var/lib/apt/lists/*

# The unprivileged worker account (mirrors dist/sysusers.d/quishd.conf) …
RUN useradd --system --home-dir /nonexistent --shell /usr/sbin/nologin quish && \
    # … and a normal login user the sessions setuid to. Password is a TEST
    # credential for this throwaway container only — never a real secret.
    useradd --create-home --shell /bin/bash quishtest && \
    echo 'quishtest:quishtestpw' | chpasswd && \
    # Chroot root for the worker (root-owned, empty).
    mkdir -p /run/quishd && chown root:root /run/quishd

# PAM policy for the `quish` service (matches dist/pam.d/quish).
COPY dist/pam.d/quish /etc/pam.d/quish

WORKDIR /src
COPY . .

# Login user + password the Rust harness authenticates as (read from env there).
ENV QUISH_TEST_USER=quishtest
ENV QUISH_TEST_PASSWORD=quishtestpw
# PAM bindgen hints (see AGENTS.md) are NOT needed here: apt installed real
# clang + libclang-dev + libpam headers, so bindgen finds everything.

# Build once at image-build time so `podman run` is fast and hermetic.
RUN cargo build --workspace --features quish-server/pam

# --test-threads=1: each scenario spawns a real root monitor with a global
# /run/quishd.sock.d-<pid> socket dir and drives timing-sensitive session
# teardown; serialize so socket_dir_is_root_only sees exactly one dir and the
# reap/disconnect guards aren't perturbed by concurrent daemons.
CMD ["cargo", "test", "-p", "quish-server", "--features", "pam", \
     "--test", "privsep_e2e", "--", "--ignored", "--nocapture", "--test-threads=1"]
