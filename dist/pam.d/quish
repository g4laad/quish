# PAM policy for quish (service name "quish"; install to /etc/pam.d/quish).
#
# `nodelay`: quish enforces its OWN centralized constant-time failure floor in
# the auth registry, so pam_unix's built-in random delay is both redundant and
# would leak timing variance the registry works to erase. Leave it off.
auth       required   pam_unix.so nodelay
account    required   pam_unix.so

# Session stage (plan 022): run when quish opens a login session around a shell.
# Minimal login set, host policy — operators may add/remove modules.
#   pam_limits    (required): apply /etc/security/limits.conf rlimits.
#   pam_loginuid  (required): set the audit login uid for the session.
#   pam_env       (optional): load /etc/environment + /etc/security/pam_env.conf.
#   pam_lastlog   (optional, silent): record the login in lastlog/wtmp.
# NOTE: `session optional pam_systemd.so` (logind session, XDG_RUNTIME_DIR,
# per-session cgroup) is intentionally NOT enabled in this first slice: the
# rootless-podman e2e image has no systemd/logind/dbus (and no libpam-systemd),
# so it cannot be exercised here. Re-add it on systemd hosts (see plan 022).
session    required   pam_limits.so
session    required   pam_loginuid.so
session    optional   pam_env.so
session    optional   pam_lastlog.so silent
